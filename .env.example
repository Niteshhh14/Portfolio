# EmailJS Configuration Variables
# -------------------------------------------------------------
# You can find these IDs in your EmailJS Dashboard (https://dashboard.emailjs.com/)

# 1. Your EmailJS Service ID (Found in the 'Email Services' tab)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxxx 

# 2. Your EmailJS Template ID (Found in the 'Email Templates' tab)
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxxx

# 3. Your EmailJS Public Key (Found in Account -> 'API Keys' section)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
